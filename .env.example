# Copy this file to .env and fill in your values
# NEVER commit .env to git

# findaminyan.co.uk admin login
FINDAMINYAN_EMAIL=phoneservice@findaminyan.com
FINDAMINYAN_PASSWORD=your_password_here

# Twilio (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+441234567890

# Your own mobile number (gets the admin alert when a minyan is possible)
ADMIN_PHONE=+447700900000
